# ============================================================
# ENUMS (mirror TypeScript)
# ============================================================

class KPIType(str, Enum):
    CORPORATE = "corporate"
    INDIVIDUAL = "individual"


class KPIUnit(str, Enum):
    PERCENTAGE = "percentage"
    NUMBER = "number"
    CURRENCY = "currency"
    BOOLEAN = "boolean"
    SCORE = "score"


# ============================================================
# DATA CLASSES (mirror TypeScript interfaces)
# ============================================================

@dataclass
class UserSummary:
    id: str
    first_name: str
    last_name: str
    corporate_email: str
    department: str = ""

    @property
    def full_name(self) -> str:
        return f"{self.first_name} {self.last_name}"


@dataclass
class OKRSummary:
    id: str
    title: str


@dataclass
class KeyResultSummary:
    id: str
    title: str


@dataclass
class KPIRecord:
    id: str
    title: str
    type: KPIType
    unit: KPIUnit
    target_value: float
    weight: float
    period_start: date
    period_end: date
    description: str = ""
    department: str = ""
    actual_value: Optional[float] = None
    baseline_value: Optional[float] = None
    owner: Optional[UserSummary] = None
    okr: Optional[OKRSummary] = None
    key_result: Optional[KeyResultSummary] = None
    created_at: datetime = field(default_factory=datetime.utcnow)
    updated_at: datetime = field(default_factory=datetime.utcnow)

    @property
    def achievement(self) -> Optional[float]:
        if self.actual_value is not None and self.target_value:
            return min(round((self.actual_value / self.target_value) * 100, 2), 100.0)
        return None

    def format_value(self, value: Optional[float]) -> str:
        if value is None:
            return "—"
        match self.unit:
            case KPIUnit.PERCENTAGE:
                return f"{value:.1f}%"
            case KPIUnit.CURRENCY:
                return f"${value:,.2f}"
            case KPIUnit.BOOLEAN:
                return "Yes" if value else "No"
            case _:
                return f"{value:,.4g}"


# ============================================================
# STYLE HELPERS
# ============================================================

def _font(bold: bool = False, size: int = 10, color: str = "000000") -> Font:
    return Font(name="Arial", bold=bold, size=size, color=color)


def _fill(hex_color: str) -> PatternFill:
    return PatternFill("solid", fgColor=hex_color)


def _border(
    style: str = "thin",
    color: str = "BFBFBF",
) -> Border:
    side = Side(style=style, color=color)
    return Border(left=side, right=side, top=side, bottom=side)


def _center() -> Alignment:
    return Alignment(horizontal="center", vertical="center", wrap_text=True)


def _left() -> Alignment:
    return Alignment(horizontal="left", vertical="center", wrap_text=True)


HEADER_FILL = _fill("1F4E79")
HEADER_FONT = _font(bold=True, size=10, color="FFFFFF")

SUBHEADER_FILL = _fill("2E75B6")
SUBHEADER_FONT = _font(bold=True, size=10, color="FFFFFF")

CORPORATE_FILL = _fill("DEEAF1")
INDIVIDUAL_FILL = _fill("E2EFDA")

ACHIEVED_FILL = _fill("C6EFCE")
AT_RISK_FILL = _fill("FFEB9C")
BEHIND_FILL = _fill("FFC7CE")

ROW_ALT_FILL = _fill("F5F5F5")
TITLE_FONT = _font(bold=True, size=14, color="1F4E79")
SECTION_FONT = _font(bold=True, size=11, color="2E75B6")
THIN_BORDER = _border()


def _achievement_fill(achievement: Optional[float]) -> Optional[PatternFill]:
    if achievement is None:
        return None
    if achievement >= 100:
        return ACHIEVED_FILL
    if achievement >= 70:
        return AT_RISK_FILL
    return BEHIND_FILL


def _apply_row_style(
    ws,
    row: int,
    start_col: int,
    end_col: int,
    fill: Optional[PatternFill] = None,
    font: Optional[Font] = None,
    alignment: Optional[Alignment] = None,
    border: Optional[Border] = None,
) -> None:
    for col in range(start_col, end_col + 1):
        cell = ws.cell(row=row, column=col)
        if fill:
            cell.fill = fill
        if font:
            cell.font = font
        if alignment:
            cell.alignment = alignment
        if border:
            cell.border = border


def _write_header_row(ws, row: int, headers: list[str], col_start: int = 1) -> None:
    for i, h in enumerate(headers, start=col_start):
        cell = ws.cell(row=row, column=i, value=h)
        cell.font = HEADER_FONT
        cell.fill = HEADER_FILL
        cell.alignment = _center()
        cell.border = THIN_BORDER


# ============================================================
# SHEET 1 — OVERVIEW (all KPIs)
# ============================================================

_OVERVIEW_HEADERS = [
    "KPI ID",
    "Title",
    "Type",
    "Department / Owner",
    "Unit",
    "Linked OKR",
    "Linked Key Result",
    "Target",
    "Actual",
    "Achievement (%)",
    "Weight (%)",
    "Period Start",
    "Period End",
    "Status",
]

_OVERVIEW_WIDTHS = [10, 38, 12, 28, 12, 30, 30, 12, 12, 14, 10, 14, 14, 12]


def _build_overview_sheet(ws, kpis: list[KPIRecord]) -> None:
    ws.title = "KPI Overview"
    ws.freeze_panes = "A3"
    ws.row_dimensions[1].height = 20
    ws.row_dimensions[2].height = 40

    # Title row
    ws.merge_cells("A1:N1")
    title_cell = ws["A1"]
    title_cell.value = f"KPI Performance Report — Exported {datetime.utcnow().strftime('%Y-%m-%d %H:%M UTC')}"
    title_cell.font = TITLE_FONT
    title_cell.alignment = _center()
    title_cell.fill = _fill("DEEAF1")

    _write_header_row(ws, 2, _OVERVIEW_HEADERS)

    for i, kpi in enumerate(kpis, start=1):
        row = i + 2
        alt = i % 2 == 0

        owner_label = (
            kpi.owner.full_name if kpi.owner else kpi.department or "—"
        )
        achievement = kpi.achievement

        row_data: list[Any] = [
            kpi.id[:8] + "…",
            kpi.title,
            kpi.type.value.capitalize(),
            owner_label,
            kpi.unit.value.capitalize(),
            kpi.okr.title if kpi.okr else "—",
            kpi.key_result.title if kpi.key_result else "—",
            kpi.format_value(kpi.target_value),
            kpi.format_value(kpi.actual_value),
            f"{achievement:.1f}%" if achievement is not None else "—",
            f"{kpi.weight:.1f}%",
            kpi.period_start.strftime("%Y-%m-%d"),
            kpi.period_end.strftime("%Y-%m-%d"),
            _status_label(achievement),
        ]

        base_fill = CORPORATE_FILL if kpi.type == KPIType.CORPORATE else INDIVIDUAL_FILL
        row_fill = ROW_ALT_FILL if alt else None

        for col, value in enumerate(row_data, start=1):
            cell = ws.cell(row=row, column=col, value=value)
            cell.font = _font(size=10)
            cell.border = THIN_BORDER
            cell.fill = row_fill or base_fill
            cell.alignment = _center() if col in (1, 3, 5, 10, 11, 14) else _left()

        # Color-code achievement cell
        ach_fill = _achievement_fill(achievement)
        if ach_fill:
            ws.cell(row=row, column=10).fill = ach_fill

        ws.row_dimensions[row].height = 18

    for col, width in enumerate(_OVERVIEW_WIDTHS, start=1):
        ws.column_dimensions[get_column_letter(col)].width = width

    # Auto-filter
    ws.auto_filter.ref = f"A2:{get_column_letter(len(_OVERVIEW_HEADERS))}2"


def _status_label(achievement: Optional[float]) -> str:
    if achievement is None:
        return "Not Submitted"
    if achievement >= 100:
        return "Achieved"
    if achievement >= 70:
        return "At Risk"
    return "Behind"


