def _build_summary_sheet(ws, kpis: list[KPIRecord]) -> None:
    ws.title = "Summary"

    def _section_title(row: int, text: str) -> None:
        ws.merge_cells(f"A{row}:F{row}")
        c = ws.cell(row=row, column=1, value=text)
        c.font = _font(bold=True, size=11, color="1F4E79")
        c.fill = _fill("DEEAF1")
        c.alignment = _left()
        c.border = THIN_BORDER
        ws.row_dimensions[row].height = 20

    # --- KPI count by type ---
    _section_title(1, "KPI Count by Type")
    for col, h in enumerate(["Type", "Count"], start=1):
        cell = ws.cell(row=2, column=col, value=h)
        cell.font = HEADER_FONT
        cell.fill = HEADER_FILL
        cell.border = THIN_BORDER
        cell.alignment = _center()

    type_summary = {
        KPIType.CORPORATE: sum(1 for k in kpis if k.type == KPIType.CORPORATE),
        KPIType.INDIVIDUAL: sum(1 for k in kpis if k.type == KPIType.INDIVIDUAL),
    }
    for i, (kpi_type, count) in enumerate(type_summary.items(), start=3):
        ws.cell(row=i, column=1, value=kpi_type.value.capitalize()).border = THIN_BORDER
        ws.cell(row=i, column=2, value=count).border = THIN_BORDER

    # --- Achievement distribution ---
    _section_title(6, "Achievement Distribution")
    for col, h in enumerate(["Status", "Count"], start=1):
        cell = ws.cell(row=7, column=col, value=h)
        cell.font = HEADER_FONT
        cell.fill = HEADER_FILL
        cell.border = THIN_BORDER
        cell.alignment = _center()

    achieved = sum(1 for k in kpis if k.achievement is not None and k.achievement >= 100)
    at_risk   = sum(1 for k in kpis if k.achievement is not None and 70 <= k.achievement < 100)
    behind    = sum(1 for k in kpis if k.achievement is not None and k.achievement < 70)
    no_data   = sum(1 for k in kpis if k.achievement is None)

    dist = [("Achieved (≥100%)", achieved), ("At Risk (70–99%)", at_risk),
            ("Behind (<70%)", behind), ("Not Submitted", no_data)]
    fills = [ACHIEVED_FILL, AT_RISK_FILL, BEHIND_FILL, _fill("D9D9D9")]

    for i, ((label, count), fill) in enumerate(zip(dist, fills), start=8):
        c1 = ws.cell(row=i, column=1, value=label)
        c2 = ws.cell(row=i, column=2, value=count)
        for c in (c1, c2):
            c.fill = fill
            c.border = THIN_BORDER
            c.font = _font(size=10)

    # --- Bar chart ---
    chart = BarChart()
    chart.type = "col"
    chart.title = "KPI Achievement Distribution"
    chart.y_axis.title = "Count"
    chart.x_axis.title = "Status"
    chart.style = 10
    chart.width = 16
    chart.height = 10

    data_ref = Reference(ws, min_col=2, min_row=7, max_row=11)
    cats_ref = Reference(ws, min_col=1, min_row=8, max_row=11)
    chart.add_data(data_ref, titles_from_data=True)
    chart.set_categories(cats_ref)
    ws.add_chart(chart, "D2")

    # --- Average achievement by department ---
    _section_title(14, "Average Achievement by Department")
    for col, h in enumerate(["Department", "KPI Count", "Avg Achievement (%)"], start=1):
        cell = ws.cell(row=15, column=col, value=h)
        cell.font = HEADER_FONT
        cell.fill = HEADER_FILL
        cell.border = THIN_BORDER
        cell.alignment = _center()

    dept_data: dict[str, list[float]] = {}
    for k in kpis:
        dept = k.department or (k.owner.department if k.owner else "Unknown") or "Unknown"
        if k.achievement is not None:
            dept_data.setdefault(dept, []).append(k.achievement)

    for i, (dept, achievements) in enumerate(sorted(dept_data.items()), start=16):
        avg = round(sum(achievements) / len(achievements), 2) if achievements else 0
        ws.cell(row=i, column=1, value=dept).border = THIN_BORDER
        ws.cell(row=i, column=2, value=len(achievements)).border = THIN_BORDER
        ws.cell(row=i, column=3, value=f"{avg:.1f}%").border = THIN_BORDER

    for col, width in zip(range(1, 7), [28, 12, 22, 14, 14, 14]):
        ws.column_dimensions[get_column_letter(col)].width = width


# ============================================================
# MAIN EXPORT FUNCTION
# ============================================================

def export_kpis_to_excel(
    kpis: list[KPIRecord],
    output_path: Optional[str] = None,
) -> bytes:
    """
    Export a list of KPIRecord objects to a formatted Excel workbook.

    Sheets:
      1. KPI Overview      — all KPIs in a single filterable table
      2. Corporate KPIs    — department-grouped corporate KPIs
      3. Individual KPIs   — employee-grouped individual KPIs
      4. OKR–KPI Alignment — OKR → KeyResult → KPI hierarchy
      5. Summary           — counts, achievement distribution, bar chart

    Args:
        kpis:        List of KPIRecord data objects.
        output_path: If provided, saves the file to disk; otherwise returns raw bytes.

    Returns:
        The Excel file as bytes (also written to output_path if given).
    """
    wb = Workbook()

    # Remove default sheet
    wb.remove(wb.active)

    _build_overview_sheet(wb.create_sheet(), kpis)
    _build_corporate_sheet(wb.create_sheet(), kpis)
    _build_individual_sheet(wb.create_sheet(), kpis)
    _build_alignment_sheet(wb.create_sheet(), kpis)
    _build_summary_sheet(wb.create_sheet(), kpis)

    if output_path:
        wb.save(output_path)

    buf = io.BytesIO()
    wb.save(buf)
    buf.seek(0)
    return buf.read()


