def _build_individual_sheet(ws, kpis: list[KPIRecord]) -> None:
    ws.title = "Individual KPIs"
    ws.freeze_panes = "A3"
    ws.row_dimensions[2].height = 36

    ws.merge_cells(f"A1:{get_column_letter(len(_IND_HEADERS))}1")
    hdr = ws["A1"]
    hdr.value = "Individual KPIs"
    hdr.font = _font(bold=True, size=12, color="FFFFFF")
    hdr.fill = _fill("375623")
    hdr.alignment = _center()

    _write_header_row(ws, 2, _IND_HEADERS)

    ind_kpis = [k for k in kpis if k.type == KPIType.INDIVIDUAL]

    # Group by owner
    by_owner: dict[str, list[KPIRecord]] = {}
    for k in ind_kpis:
        label = k.owner.full_name if k.owner else "Unknown"
        by_owner.setdefault(label, []).append(k)

    row = 3
    for owner_name, owner_kpis in sorted(by_owner.items()):
        ws.merge_cells(f"A{row}:{get_column_letter(len(_IND_HEADERS))}{row}")
        grp_cell = ws.cell(row=row, column=1, value=f"▸  {owner_name}")
        grp_cell.font = _font(bold=True, size=10, color="375623")
        grp_cell.fill = _fill("D9EAD3")
        grp_cell.alignment = _left()
        grp_cell.border = THIN_BORDER
        ws.row_dimensions[row].height = 18
        row += 1

        for i, kpi in enumerate(owner_kpis):
            alt = i % 2 == 0
            achievement = kpi.achievement

            row_data: list[Any] = [
                kpi.owner.full_name if kpi.owner else "—",
                kpi.owner.corporate_email if kpi.owner else "—",
                kpi.title,
                kpi.unit.value.capitalize(),
                kpi.okr.title if kpi.okr else "—",
                kpi.key_result.title if kpi.key_result else "—",
                kpi.format_value(kpi.target_value),
                kpi.format_value(kpi.actual_value),
                f"{achievement:.1f}%" if achievement is not None else "—",
                f"{kpi.weight:.1f}%",
                f"{kpi.period_start.strftime('%Y-%m-%d')} → {kpi.period_end.strftime('%Y-%m-%d')}",
            ]

            for col, value in enumerate(row_data, start=1):
                cell = ws.cell(row=row, column=col, value=value)
                cell.font = _font(size=10)
                cell.border = THIN_BORDER
                cell.fill = ROW_ALT_FILL if alt else INDIVIDUAL_FILL
                cell.alignment = _center() if col in (4, 9, 10) else _left()

            ach_fill = _achievement_fill(achievement)
            if ach_fill:
                ws.cell(row=row, column=9).fill = ach_fill

            ws.row_dimensions[row].height = 18
            row += 1

    for col, width in enumerate(_IND_WIDTHS, start=1):
        ws.column_dimensions[get_column_letter(col)].width = width


