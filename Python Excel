def _build_alignment_sheet(ws, kpis: list[KPIRecord]) -> None:
    ws.title = "OKR–KPI Alignment"
    ws.freeze_panes = "A3"
    ws.row_dimensions[2].height = 36

    headers = ["OKR", "Key Result", "KPI Title", "Type", "Owner / Dept", "Target", "Actual", "Achievement (%)"]
    widths = [38, 34, 38, 12, 28, 12, 12, 14]

    ws.merge_cells(f"A1:{get_column_letter(len(headers))}1")
    t = ws["A1"]
    t.value = "OKR → Key Result → KPI Alignment"
    t.font = _font(bold=True, size=12, color="FFFFFF")
    t.fill = _fill("7030A0")
    t.alignment = _center()

    _write_header_row(ws, 2, headers)

    linked = [k for k in kpis if k.okr]
    unlinked = [k for k in kpis if not k.okr]

    by_okr: dict[str, list[KPIRecord]] = {}
    for k in linked:
        by_okr.setdefault(k.okr.title, []).append(k)  # type: ignore[union-attr]

    row = 3
    for okr_title, okr_kpis in sorted(by_okr.items()):
        ws.merge_cells(f"A{row}:{get_column_letter(len(headers))}{row}")
        cell = ws.cell(row=row, column=1, value=f"OKR: {okr_title}")
        cell.font = _font(bold=True, size=10, color="FFFFFF")
        cell.fill = _fill("7030A0")
        cell.alignment = _left()
        cell.border = THIN_BORDER
        ws.row_dimensions[row].height = 18
        row += 1

        for i, kpi in enumerate(okr_kpis):
            alt = i % 2 == 0
            achievement = kpi.achievement
            owner_label = kpi.owner.full_name if kpi.owner else kpi.department or "—"

            row_data: list[Any] = [
                kpi.okr.title if kpi.okr else "—",
                kpi.key_result.title if kpi.key_result else "—",
                kpi.title,
                kpi.type.value.capitalize(),
                owner_label,
                kpi.format_value(kpi.target_value),
                kpi.format_value(kpi.actual_value),
                f"{achievement:.1f}%" if achievement is not None else "—",
            ]

            for col, value in enumerate(row_data, start=1):
                cell = ws.cell(row=row, column=col, value=value)
                cell.font = _font(size=10)
                cell.border = THIN_BORDER
                cell.fill = ROW_ALT_FILL if alt else _fill("EDE7F6")
                cell.alignment = _left()

            ach_fill = _achievement_fill(achievement)
            if ach_fill:
                ws.cell(row=row, column=8).fill = ach_fill

            ws.row_dimensions[row].height = 18
            row += 1

    if unlinked:
        ws.merge_cells(f"A{row}:{get_column_letter(len(headers))}{row}")
        u = ws.cell(row=row, column=1, value="KPIs without OKR linkage")
        u.font = _font(bold=True, size=10, color="595959")
        u.fill = _fill("D9D9D9")
        u.alignment = _left()
        u.border = THIN_BORDER
        ws.row_dimensions[row].height = 18
        row += 1

        for kpi in unlinked:
            owner_label = kpi.owner.full_name if kpi.owner else kpi.department or "—"
            for col, value in enumerate(
                ["—", "—", kpi.title, kpi.type.value.capitalize(), owner_label,
                 kpi.format_value(kpi.target_value), kpi.format_value(kpi.actual_value), "—"],
                start=1,
            ):
                cell = ws.cell(row=row, column=col, value=value)
                cell.font = _font(size=10, color="595959")
                cell.border = THIN_BORDER
                cell.alignment = _left()
            row += 1

    for col, width in enumerate(widths, start=1):
        ws.column_dimensions[get_column_letter(col)].width = width


