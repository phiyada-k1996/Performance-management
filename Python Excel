def _build_corporate_sheet(ws, kpis: list[KPIRecord]) -> None:
    ws.title = "Corporate KPIs"
    ws.freeze_panes = "A3"
    ws.row_dimensions[2].height = 36

    ws.merge_cells(f"A1:{get_column_letter(len(_CORP_HEADERS))}1")
    hdr = ws["A1"]
    hdr.value = "Corporate KPIs"
    hdr.font = SECTION_FONT
    hdr.fill = SUBHEADER_FILL
    hdr.font = _font(bold=True, size=12, color="FFFFFF")
    hdr.alignment = _center()

    _write_header_row(ws, 2, _CORP_HEADERS)

    corp_kpis = [k for k in kpis if k.type == KPIType.CORPORATE]

    # Group by department
    departments: dict[str, list[KPIRecord]] = {}
    for k in corp_kpis:
        departments.setdefault(k.department or "General", []).append(k)

    row = 3
    for dept, dept_kpis in sorted(departments.items()):
        # Department sub-header
        ws.merge_cells(f"A{row}:{get_column_letter(len(_CORP_HEADERS))}{row}")
        dept_cell = ws.cell(row=row, column=1, value=f"▸  {dept}")
        dept_cell.font = _font(bold=True, size=10, color="1F4E79")
        dept_cell.fill = _fill("D9E2F3")
        dept_cell.alignment = _left()
        dept_cell.border = THIN_BORDER
        ws.row_dimensions[row].height = 18
        row += 1

        for i, kpi in enumerate(dept_kpis):
            alt = i % 2 == 0
            achievement = kpi.achievement

            row_data: list[Any] = [
                kpi.title,
                kpi.department or "—",
                kpi.unit.value.capitalize(),
                kpi.okr.title if kpi.okr else "—",
                kpi.key_result.title if kpi.key_result else "—",
                kpi.format_value(kpi.target_value),
                kpi.format_value(kpi.actual_value),
                f"{achievement:.1f}%" if achievement is not None else "—",
                f"{kpi.weight:.1f}%",
                f"{kpi.period_start.strftime('%Y-%m-%d')} → {kpi.period_end.strftime('%Y-%m-%d')}",
            ]

            for col, value in enumerate(row_data, start=1):
                cell = ws.cell(row=row, column=col, value=value)
                cell.font = _font(size=10)
                cell.border = THIN_BORDER
                cell.fill = ROW_ALT_FILL if alt else CORPORATE_FILL
                cell.alignment = _center() if col in (3, 8, 9) else _left()

            ach_fill = _achievement_fill(achievement)
            if ach_fill:
                ws.cell(row=row, column=8).fill = ach_fill

            ws.row_dimensions[row].height = 18
            row += 1

    for col, width in enumerate(_CORP_WIDTHS, start=1):
        ws.column_dimensions[get_column_letter(col)].width = width


