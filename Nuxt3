              <div class="space-y-2 max-h-72 overflow-y-auto pr-1">
                <label
                  v-for="kpi in allKpis"
                  :key="kpi.id"
                  :class="[
                    'flex items-center gap-3 p-3 rounded-xl border cursor-pointer transition-all duration-150',
                    bulkForm.selectedIds.includes(kpi.id)
                      ? 'border-red-400 bg-red-50'
                      : 'border-slate-200 hover:border-slate-300 bg-white'
                  ]"
                >
                  <input
                    type="checkbox"
                    :value="kpi.id"
                    v-model="bulkForm.selectedIds"
                    class="w-4 h-4 text-red-600 border-slate-300 rounded focus:ring-red-500"
                  />
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-semibold text-slate-800 truncate">{{ kpi.title }}</p>
                    <p class="text-xs text-slate-500">{{ kpi.department || kpi.owner }} · Target: {{ kpi.target }}</p>
                  </div>
                  <span :class="['text-xs font-semibold px-2 py-0.5 rounded flex-shrink-0', kpi.type === 'corporate' ? 'bg-blue-100 text-blue-700' : 'bg-red-100 text-red-700']">{{ kpi.type }}</span>
                </label>
              </div>
              <button
                type="button"
                @click="bulkForm.selectedIds = allKpis.map(k => k.id)"
                class="mt-2 text-xs text-blue-600 hover:text-blue-800 font-semibold"
              >
                Select all
              </button>
              <span class="mx-2 text-slate-300">·</span>
              <button type="button" @click="bulkForm.selectedIds = []" class="text-xs text-slate-500 hover:text-slate-700 font-semibold">Clear</button>
