                Select KPIs
                <span v-if="bulkForm.selectedIds.length" class="ml-2 inline-flex items-center justify-center w-5 h-5 rounded-full bg-red-600 text-white text-xs font-bold">{{ bulkForm.selectedIds.length }}</span>
