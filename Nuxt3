            <!-- Warning -->
            <div v-if="bulkForm.selectedIds.length > 0" class="flex items-start gap-3 bg-amber-50 border border-amber-200 rounded-xl p-4">
              <svg class="w-4 h-4 text-amber-600 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/></svg>
              <p class="text-xs text-amber-700 leading-relaxed">
                You are about to submit actual value <strong>{{ bulkForm.actualValue || '—' }}</strong> to <strong>{{ bulkForm.selectedIds.length }}</strong> KPI{{ bulkForm.selectedIds.length > 1 ? 's' : '' }}. This action cannot be undone automatically.
              </p>
            </div>

            <button
              @click="handleBulkSubmit"
              :disabled="isSubmitting || bulkForm.selectedIds.length === 0 || bulkForm.actualValue == null"
              class="w-full flex items-center justify-center gap-2 py-3 rounded-xl bg-red-600 hover:bg-red-700 text-white font-bold text-sm transition-all duration-200 shadow-lg shadow-red-200 disabled:opacity-50 disabled:cursor-not-allowed"
            >
              <svg v-if="isSubmitting" class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
              <svg v-else class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>
              {{ isSubmitting ? 'Submitting…' : `Bulk Submit to ${bulkForm.selectedIds.length || 0} KPI${bulkForm.selectedIds.length !== 1 ? 's' : ''}` }}
            </button>
          </div>
        </div>
      </div>

    </main>

    <!-- ══════════════════════════════════════════════════════ -->
