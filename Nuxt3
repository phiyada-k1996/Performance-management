        <span>PerformOS · Performance Management System</span>
        <div class="flex items-center gap-4">
          <span>API: <code class="bg-slate-200 text-slate-600 px-1.5 py-0.5 rounded">/api/v1/kpis</code></span>
          <span class="text-slate-300">·</span>
          <span>v1.0.0</span>
        </div>
      </div>
    </footer>
  </div>
</template>

<script setup lang="ts">
// ─── Nuxt / Vue ─────────────────────────────────────────────
import { ref, reactive, computed, watch } from 'vue'

// ─── Types ──────────────────────────────────────────────────
type KPIType = 'corporate' | 'individual'

interface SelectKpi {
  id: string
  title: string
  type: KPIType
  department?: string
  owner?: string
  target: string
  unit: string
}

interface QuickPeriod {
  label: string
  start: string
  end: string
}

// ─── Constants ───────────────────────────────────────────────
const API_BASE = '/api/v1/kpis'

const departments = [
  'Engineering', 'Product', 'Sales', 'Marketing',
  'Customer Success', 'Finance', 'Legal', 'HR', 'Operations',
]

const units = [
  { value: 'percentage', label: '%', icon: '📊' },
  { value: 'number',     label: 'Number', icon: '🔢' },
  { value: 'currency',   label: 'USD',    icon: '💲' },
  { value: 'boolean',    label: 'Yes/No', icon: '✅' },
  { value: 'score',      label: 'Score',  icon: '⭐' },
  { value: 'text',       label: 'Custom', icon: '📝' },
]

// Mock data — replace with useFetch / useAsyncData in production
const users = ref([
  { id: 'u1', name: 'Alice Chen',     email: 'alice.chen@corp.com' },
  { id: 'u2', name: 'Bob Kim',        email: 'bob.kim@corp.com' },
  { id: 'u3', name: 'Clara Moss',     email: 'clara.moss@corp.com' },
  { id: 'u4', name: 'David Tanaka',   email: 'david.tanaka@corp.com' },
])

const okrs = ref([
  { id: 'o1', title: 'Achieve 99% platform uptime in Q2' },
  { id: 'o2', title: 'Grow APAC revenue by 20%' },
  { id: 'o3', title: 'Improve NPS score to 60+ by year-end' },
])

const keyResults = ref([
  { id: 'kr1', okrId: 'o1', title: 'Reduce incident count below 5 per month' },
  { id: 'kr2', okrId: 'o1', title: 'Deploy automated monitoring for all services' },
  { id: 'kr3', okrId: 'o2', title: 'Close 15 enterprise APAC deals' },
  { id: 'kr4', okrId: 'o2', title: 'Launch in 3 new APAC markets' },
  { id: 'kr5', okrId: 'o3', title: 'Survey 500+ customers per quarter' },
])

const allKpis = ref<SelectKpi[]>([
  { id: 'kpi-001', title: 'Platform Uptime',        type: 'corporate',   department: 'Engineering', target: '99%',    unit: 'percentage' },
  { id: 'kpi-002', title: 'Monthly Incident Count', type: 'corporate',   department: 'Engineering', target: '5',      unit: 'number'     },
  { id: 'kpi-003', title: 'APAC Revenue',           type: 'corporate',   department: 'Sales',       target: '$2M',    unit: 'currency'   },
  { id: 'kpi-004', title: 'PRs Reviewed',           type: 'individual',  owner: 'Alice Chen',       target: '40',     unit: 'number'     },
  { id: 'kpi-005', title: 'Enterprise Deals Closed',type: 'individual',  owner: 'Bob Kim',          target: '15',     unit: 'number'     },
  { id: 'kpi-006', title: 'CSAT Score',             type: 'individual',  owner: 'Bob Kim',          target: '4.5',    unit: 'score'      },
])

// ─── State ───────────────────────────────────────────────────
const activeMainTab = ref<'create' | 'submit' | 'bulk'>('create')
const kpiType       = ref<KPIType>('corporate')
const isSubmitting  = ref(false)
const selectedQuickPeriod = ref('')

const mainTabs = [
  { id: 'create' as const, label: 'Create KPI'   },
  { id: 'submit' as const, label: 'Submit Value'  },
  { id: 'bulk'   as const, label: 'Bulk Submit'   },
]

// ─── Toast ───────────────────────────────────────────────────
const toast = reactive({ show: false, type: 'success' as 'success' | 'error', message: '' })
let toastTimer: ReturnType<typeof setTimeout>

function showToast(type: 'success' | 'error', message: string) {
  clearTimeout(toastTimer)
  toast.type    = type
  toast.message = message
  toast.show    = true
  toastTimer    = setTimeout(() => { toast.show = false }, 4000)
}

// ─── Create KPI Form ─────────────────────────────────────────
const emptyForm = () => ({
  title:        '',
  description:  '',
  department:   '',
  ownerId:      '',
  unit:         '',
  targetValue:  null as number | null,
  baselineValue: null as number | null,
  weight:       null as number | null,
  periodStart:  '',
  periodEnd:    '',
  okrId:        '',
  keyResultId:  '',
})

const form   = reactive(emptyForm())
const errors = reactive<Record<string, string>>({})

const inputClass = (error?: string) =>
  `w-full rounded-lg border px-3 py-2.5 text-sm text-slate-800 bg-white transition-colors duration-150 focus:outline-none focus:ring-2 ${
    error
      ? 'border-red-400 focus:border-red-500 focus:ring-red-100'
      : 'border-slate-200 focus:border-blue-500 focus:ring-blue-100'
  }`

function validateField(field: string) {
  errors[field] = ''
  if (field === 'title'       && !form.title.trim())                             errors.title       = 'KPI title is required'
  if (field === 'department'  && kpiType.value === 'corporate' && !form.department) errors.department = 'Department is required'
  if (field === 'unit'        && !form.unit)                                      errors.unit        = 'Select a unit'
  if (field === 'targetValue' && (form.targetValue == null || form.targetValue < 0)) errors.targetValue = 'Enter a valid target ≥ 0'
  if (field === 'weight'      && (form.weight == null || form.weight < 0 || form.weight > 100)) errors.weight = 'Weight must be 0–100'
  if (field === 'periodStart' && !form.periodStart)                               errors.periodStart = 'Start date is required'
  if (field === 'periodEnd'   && !form.periodEnd)                                 errors.periodEnd   = 'End date is required'
  if (field === 'periodEnd'   && form.periodStart && form.periodEnd && form.periodEnd <= form.periodStart)
    errors.periodEnd = 'End date must be after start date'
}

function validateCreateForm() {
  const fields = ['title', 'unit', 'targetValue', 'weight', 'periodStart', 'periodEnd']
  if (kpiType.value === 'corporate') fields.push('department')
  fields.forEach(validateField)
  return !Object.values(errors).some(Boolean)
}

function resetForm() {
  Object.assign(form, emptyForm())
  Object.keys(errors).forEach(k => { errors[k] = '' })
  selectedQuickPeriod.value = ''
}

watch(kpiType, resetForm)

// Quick period presets
const now = new Date()
const quickPeriods = computed<QuickPeriod[]>(() => {
  const y = now.getFullYear()
  const m = now.getMonth()
  const q = Math.floor(m / 3)

  return [
    { label: 'This Month', start: `${y}-${String(m + 1).padStart(2, '0')}-01`, end: new Date(y, m + 1, 0).toISOString().split('T')[0] },
    { label: 'Q1', start: `${y}-01-01`, end: `${y}-03-31` },
    { label: 'Q2', start: `${y}-04-01`, end: `${y}-06-30` },
    { label: 'Q3', start: `${y}-07-01`, end: `${y}-09-30` },
    { label: 'Q4', start: `${y}-10-01`, end: `${y}-12-31` },
    { label: 'Annual', start: `${y}-01-01`, end: `${y}-12-31` },
  ]
})

function applyQuickPeriod(p: QuickPeriod) {
  form.periodStart      = p.start
  form.periodEnd        = p.end
  selectedQuickPeriod.value = p.label
  errors.periodStart    = ''
  errors.periodEnd      = ''
}

const filteredKeyResults = computed(() =>
  form.okrId ? keyResults.value.filter(kr => kr.okrId === form.okrId) : []
)

async function handleCreateSubmit() {
  if (!validateCreateForm()) return
  isSubmitting.value = true

  try {
    const endpoint = kpiType.value === 'corporate' ? `${API_BASE}/corporate` : `${API_BASE}/individual`
    const payload: Record<string, unknown> = {
      title:        form.title.trim(),
      unit:         form.unit,
      targetValue:  form.targetValue,
      weight:       form.weight,
      periodStart:  form.periodStart,
      periodEnd:    form.periodEnd,
    }
    if (form.description)  payload.description  = form.description.trim()
    if (form.baselineValue != null) payload.baselineValue = form.baselineValue
    if (form.okrId)        payload.okrId        = form.okrId
    if (form.keyResultId)  payload.keyResultId  = form.keyResultId
    if (kpiType.value === 'corporate' && form.department) payload.department = form.department
    if (kpiType.value === 'individual' && form.ownerId)   payload.ownerId    = form.ownerId

    const res = await $fetch(endpoint, { method: 'POST', body: payload })
    showToast('success', `${kpiType.value === 'corporate' ? 'Corporate' : 'Individual'} KPI created successfully!`)
    resetForm()
  } catch (err: unknown) {
    const msg = (err as { data?: { message?: string } })?.data?.message ?? 'Failed to create KPI'
    showToast('error', msg)
  } finally {
    isSubmitting.value = false
  }
}

// ─── Submit Actual Value ─────────────────────────────────────
const submitForm   = reactive({ kpiId: '', actualValue: null as number | null, comment: '' })
const submitErrors = reactive<Record<string, string>>({})

const selectedKpi = computed(() =>
  submitForm.kpiId ? allKpis.value.find(k => k.id === submitForm.kpiId) : null
)

const previewAchievement = computed(() => {
  if (!selectedKpi.value || submitForm.actualValue == null) return 0
  const target = parseFloat(selectedKpi.value.target.replace(/[$%,]/g, ''))
  if (!target) return 0
  return Math.min(Math.round((submitForm.actualValue / target) * 100), 100)
})

const kpiGroups = computed(() => [
  { label: 'Corporate KPIs',   kpis: allKpis.value.filter(k => k.type === 'corporate') },
  { label: 'Individual KPIs',  kpis: allKpis.value.filter(k => k.type === 'individual') },
])

function onKpiSelect() { submitErrors.kpiId = '' }
function onActualValueInput() { submitErrors.actualValue = '' }

async function handleActualSubmit() {
  submitErrors.kpiId = submitErrors.actualValue = ''
  if (!submitForm.kpiId)                    submitErrors.kpiId = 'Select a KPI'
  if (submitForm.actualValue == null)       submitErrors.actualValue = 'Enter actual value'
  if (Object.values(submitErrors).some(Boolean)) return

  isSubmitting.value = true
  try {
    await $fetch(`${API_BASE}/${submitForm.kpiId}/submit`, {
      method: 'PUT',
      body: { actualValue: submitForm.actualValue, comment: submitForm.comment },
    })
    showToast('success', 'Actual value submitted successfully!')
    submitForm.kpiId = ''
    submitForm.actualValue = null
    submitForm.comment = ''
  } catch (err: unknown) {
    const msg = (err as { data?: { message?: string } })?.data?.message ?? 'Submission failed'
    showToast('error', msg)
  } finally {
    isSubmitting.value = false
  }
}

// ─── Bulk Submit ─────────────────────────────────────────────
const bulkForm   = reactive({ selectedIds: [] as string[], actualValue: null as number | null, asOfDate: '' })
const bulkErrors = reactive<Record<string, string>>({})

async function handleBulkSubmit() {
  bulkErrors.actualValue = ''
  if (bulkForm.selectedIds.length === 0) return
  if (bulkForm.actualValue == null) { bulkErrors.actualValue = 'Enter actual value'; return }

  isSubmitting.value = true
  try {
    const payload: Record<string, unknown> = {
      kpiIds:      bulkForm.selectedIds,
      actualValue: bulkForm.actualValue,
    }
    if (bulkForm.asOfDate) payload.asOfDate = bulkForm.asOfDate

    await $fetch(`${API_BASE}/bulk-submit`, { method: 'POST', body: payload })
    showToast('success', `Submitted to ${bulkForm.selectedIds.length} KPI${bulkForm.selectedIds.length > 1 ? 's' : ''} successfully!`)
    bulkForm.selectedIds  = []
    bulkForm.actualValue  = null
    bulkForm.asOfDate     = ''
  } catch (err: unknown) {
    const msg = (err as { data?: { message?: string } })?.data?.message ?? 'Bulk submission failed'
    showToast('error', msg)
  } finally {
    isSubmitting.value = false
  }
}
</script>

