        <div class="rounded-2xl border border-slate-200 bg-white shadow-sm overflow-hidden">
          <div class="bg-red-700 px-7 py-5">
            <h2 class="font-display font-bold text-white text-xl">Bulk Submit</h2>
            <p class="text-red-200 text-sm mt-1">Submit the same actual value to multiple KPIs in one operation.</p>
            <code class="inline-block mt-2 text-xs bg-red-800 text-red-100 px-2 py-0.5 rounded">POST /api/v1/kpis/bulk-submit</code>
