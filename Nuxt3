            <!-- Actual Value -->
            <FormField label="Actual Value (applied to all selected)" required :error="bulkErrors.actualValue">
              <input
                v-model.number="bulkForm.actualValue"
                type="number"
                min="0"
                step="any"
                placeholder="Value to apply to all selected KPIs"
                :class="inputClass(bulkErrors.actualValue)"
