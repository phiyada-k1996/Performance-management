@ApiTags("KPIs")
@ApiBearerAuth()
@UseGuards(JwtAuthGuard, RolesGuard)
@Controller("api/v1/kpis")
export class KPIController {
  private readonly logger = new Logger(KPIController.name);

  constructor(private readonly kpiService: KPIService) {}

  // ----------------------------------------------------------
  // POST /api/v1/kpis/corporate
  // ----------------------------------------------------------
  @Post("corporate")
  @HttpCode(HttpStatus.CREATED)
  @ApiOperation({ summary: "Create a Corporate KPI (department-level, no individual owner)" })
  @ApiResponse({ status: 201, description: "Corporate KPI created" })
  @ApiResponse({ status: 400, description: "Validation error" })
  async createCorporateKPI(
    @Body() dto: CreateCorporateKPIDto,
  ): Promise<KPIResponseDto> {
    this.logger.log(`Creating corporate KPI: ${dto.title}`);
    const kpi = await this.kpiService.createCorporateKPI(dto);
    return KPIResponseDto.fromEntity(kpi);
  }

  // ----------------------------------------------------------
  // POST /api/v1/kpis/individual
  // ----------------------------------------------------------
  @Post("individual")
  @HttpCode(HttpStatus.CREATED)
  @ApiOperation({
    summary: "Create an Individual KPI (linked to a specific employee)",
  })
  @ApiResponse({ status: 201, description: "Individual KPI created" })
  async createIndividualKPI(
    @Body() dto: CreateIndividualKPIDto,
    @Request() req: { user: { id: string } },
  ): Promise<KPIResponseDto> {
    this.logger.log(`Creating individual KPI for owner: ${dto.ownerId ?? req.user.id}`);
    const kpi = await this.kpiService.createIndividualKPI(dto, req.user.id);
    return KPIResponseDto.fromEntity(kpi);
  }

  // ----------------------------------------------------------
  // GET /api/v1/kpis
  // ----------------------------------------------------------
  @Get()
  @ApiOperation({ summary: "List KPIs with optional filters" })
  @ApiQuery({ name: "type", enum: KPIType, required: false })
  @ApiQuery({ name: "department", required: false })
  @ApiQuery({ name: "ownerId", required: false })
  @ApiQuery({ name: "okrId", required: false })
  @ApiQuery({ name: "periodStart", required: false })
  @ApiQuery({ name: "periodEnd", required: false })
  async findAll(@Query() query: KPIQueryDto): Promise<KPIResponseDto[]> {
    const kpis = await this.kpiService.findAll(query);
    return kpis.map(KPIResponseDto.fromEntity);
  }

  // ----------------------------------------------------------
  // GET /api/v1/kpis/:id
  // ----------------------------------------------------------
  @Get(":id")
  @ApiOperation({ summary: "Get a single KPI by ID" })
  @ApiParam({ name: "id", type: "string", format: "uuid" })
  async findOne(@Param("id", ParseUUIDPipe) id: string): Promise<KPIResponseDto> {
    const kpi = await this.kpiService.findOne(id);
    return KPIResponseDto.fromEntity(kpi);
  }

  // ----------------------------------------------------------
  // GET /api/v1/kpis/okr/:okrId
  // ----------------------------------------------------------
  @Get("okr/:okrId")
  @ApiOperation({
    summary: "Get all KPIs linked to an OKR (corporate + individual)",
  })
  @ApiParam({ name: "okrId", type: "string", format: "uuid" })
  async findByOKR(
    @Param("okrId", ParseUUIDPipe) okrId: string,
  ): Promise<KPIResponseDto[]> {
    const kpis = await this.kpiService.findByOKR(okrId);
    return kpis.map(KPIResponseDto.fromEntity);
  }

  // ----------------------------------------------------------
  // GET /api/v1/kpis/key-result/:keyResultId
  // ----------------------------------------------------------
  @Get("key-result/:keyResultId")
  @ApiOperation({ summary: "Get all KPIs linked to a specific Key Result" })
  @ApiParam({ name: "keyResultId", type: "string", format: "uuid" })
  async findByKeyResult(
    @Param("keyResultId", ParseUUIDPipe) keyResultId: string,
  ): Promise<KPIResponseDto[]> {
    const kpis = await this.kpiService.findByKeyResult(keyResultId);
    return kpis.map(KPIResponseDto.fromEntity);
  }

  // ----------------------------------------------------------
  // PUT /api/v1/kpis/:id/submit
  // ----------------------------------------------------------
  @Put(":id/submit")
  @HttpCode(HttpStatus.OK)
  @ApiOperation({
    summary: "Submit actual value for a KPI (self or manager update)",
  })
  @ApiParam({ name: "id", type: "string", format: "uuid" })
  @ApiResponse({ status: 200, description: "Actual value submitted" })
  @ApiResponse({ status: 403, description: "Forbidden — not the KPI owner or manager" })
  async submitActualValue(
    @Param("id", ParseUUIDPipe) id: string,
    @Body() dto: UpdateKPIActualValueDto,
    @Request() req: { user: { id: string } },
  ): Promise<KPIResponseDto> {
    this.logger.log(`Submitting actual value for KPI ${id} by user ${req.user.id}`);
    const kpi = await this.kpiService.submitActualValue(id, dto, req.user.id);
    return KPIResponseDto.fromEntity(kpi);
  }

  // ----------------------------------------------------------
  // POST /api/v1/kpis/bulk-submit
  // ----------------------------------------------------------
  @Post("bulk-submit")
  @HttpCode(HttpStatus.OK)
  @ApiOperation({
    summary: "Submit the same actual value to multiple KPIs at once",
  })
  @ApiResponse({ status: 200, description: "Bulk submission successful" })
  async bulkSubmit(
    @Body() dto: BulkSubmitKPIDto,
    @Request() req: { user: { id: string } },
  ): Promise<KPIResponseDto[]> {
    this.logger.log(
      `Bulk submitting actual value for ${dto.kpiIds.length} KPIs by user ${req.user.id}`,
    );
    const kpis = await this.kpiService.bulkSubmitActualValues(dto, req.user.id);
    return kpis.map(KPIResponseDto.fromEntity);
  }
}

