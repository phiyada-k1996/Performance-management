@Injectable()
export class KPIService {
  private readonly logger = new Logger(KPIService.name);

  constructor(
    @InjectRepository(KPI)
    private readonly kpiRepository: Repository<KPI>,
    @InjectRepository(User)
    private readonly userRepository: Repository<User>,
    @InjectRepository(OKR)
    private readonly okrRepository: Repository<OKR>,
    @InjectRepository(KeyResult)
    private readonly keyResultRepository: Repository<KeyResult>,
  ) {}

  async createCorporateKPI(dto: CreateCorporateKPIDto): Promise<KPI> {
    const kpi = this.kpiRepository.create({
      ...dto,
      type: KPIType.CORPORATE,
      periodStart: new Date(dto.periodStart),
      periodEnd: new Date(dto.periodEnd),
    });

    if (dto.okrId) {
      const okr = await this.okrRepository.findOne({ where: { id: dto.okrId } });
      if (!okr) throw new NotFoundException(`OKR ${dto.okrId} not found`);
      kpi.okrId = okr.id;
    }

    if (dto.keyResultId) {
      const kr = await this.keyResultRepository.findOne({ where: { id: dto.keyResultId } });
      if (!kr) throw new NotFoundException(`KeyResult ${dto.keyResultId} not found`);
      if (dto.okrId && kr.okrId !== dto.okrId) {
        throw new BadRequestException("KeyResult does not belong to the specified OKR");
      }
      kpi.keyResultId = kr.id;
    }

    return this.kpiRepository.save(kpi);
  }

  async createIndividualKPI(dto: CreateIndividualKPIDto, requesterId: string): Promise<KPI> {
    const targetOwnerId = dto.ownerId ?? requesterId;

    const owner = await this.userRepository.findOne({ where: { id: targetOwnerId } });
    if (!owner) throw new NotFoundException(`User ${targetOwnerId} not found`);

    const kpi = this.kpiRepository.create({
      ...dto,
      type: KPIType.INDIVIDUAL,
      ownerId: targetOwnerId,
      periodStart: new Date(dto.periodStart),
      periodEnd: new Date(dto.periodEnd),
    });

    if (dto.okrId) {
      const okr = await this.okrRepository.findOne({ where: { id: dto.okrId } });
      if (!okr) throw new NotFoundException(`OKR ${dto.okrId} not found`);
      if (okr.ownerId !== targetOwnerId) {
        throw new ForbiddenException("OKR does not belong to the KPI owner");
      }
      kpi.okrId = okr.id;
    }

    if (dto.keyResultId) {
      const kr = await this.keyResultRepository.findOne({ where: { id: dto.keyResultId } });
      if (!kr) throw new NotFoundException(`KeyResult ${dto.keyResultId} not found`);
      kpi.keyResultId = kr.id;
    }

    return this.kpiRepository.save(kpi);
  }

  async submitActualValue(
    kpiId: string,
    dto: UpdateKPIActualValueDto,
    requesterId: string,
  ): Promise<KPI> {
    const kpi = await this.kpiRepository.findOne({
      where: { id: kpiId },
      relations: ["owner"],
    });

    if (!kpi) throw new NotFoundException(`KPI ${kpiId} not found`);

    if (kpi.type === KPIType.INDIVIDUAL && kpi.ownerId !== requesterId) {
      const requester = await this.userRepository.findOne({ where: { id: requesterId } });
      const isManager = requester && kpi.owner?.managerId === requesterId;
      if (!isManager) {
        throw new ForbiddenException("You can only update your own KPIs");
      }
    }

    kpi.actualValue = dto.actualValue;
    return this.kpiRepository.save(kpi);
  }

  async bulkSubmitActualValues(dto: BulkSubmitKPIDto, requesterId: string): Promise<KPI[]> {
    const kpis = await this.kpiRepository.findByIds(dto.kpiIds, { relations: ["owner"] });

    if (kpis.length !== dto.kpiIds.length) {
      const found = kpis.map((k) => k.id);
      const missing = dto.kpiIds.filter((id) => !found.includes(id));
      throw new NotFoundException(`KPIs not found: ${missing.join(", ")}`);
    }

    for (const kpi of kpis) {
      if (kpi.type === KPIType.INDIVIDUAL && kpi.ownerId !== requesterId) {
        throw new ForbiddenException(`Not authorized to update KPI ${kpi.id}`);
      }
      kpi.actualValue = dto.actualValue;
    }

    return this.kpiRepository.save(kpis);
  }

  async findAll(query: KPIQueryDto): Promise<KPI[]> {
    const where: Record<string, unknown> = {};

    if (query.type) where.type = query.type;
    if (query.department) where.department = query.department;
    if (query.ownerId) where.ownerId = query.ownerId;
    if (query.okrId) where.okrId = query.okrId;

    if (query.periodStart && query.periodEnd) {
      where.periodStart = Between(new Date(query.periodStart), new Date(query.periodEnd));
    }

    return this.kpiRepository.find({
      where,
      relations: ["owner", "okr", "keyResult"],
      order: { createdAt: "DESC" },
    });
  }

  async findOne(id: string): Promise<KPI> {
    const kpi = await this.kpiRepository.findOne({
      where: { id },
      relations: ["owner", "okr", "keyResult", "evaluations"],
    });
    if (!kpi) throw new NotFoundException(`KPI ${id} not found`);
    return kpi;
  }

  async findByOKR(okrId: string): Promise<KPI[]> {
    const okr = await this.okrRepository.findOne({ where: { id: okrId } });
    if (!okr) throw new NotFoundException(`OKR ${okrId} not found`);

    return this.kpiRepository.find({
      where: { okrId },
      relations: ["owner", "keyResult"],
      order: { type: "ASC", weight: "DESC" },
    });
  }

  async findByKeyResult(keyResultId: string): Promise<KPI[]> {
    const kr = await this.keyResultRepository.findOne({ where: { id: keyResultId } });
    if (!kr) throw new NotFoundException(`KeyResult ${keyResultId} not found`);

    return this.kpiRepository.find({
      where: { keyResultId },
      relations: ["owner", "okr"],
    });
  }
}

