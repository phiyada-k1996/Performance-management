export class KPIResponseDto {
  id: string;
  title: string;
  description?: string;
  type: KPIType;
  unit: KPIUnit;
  targetValue: number;
  actualValue?: number;
  baselineValue?: number;
  weight: number;
  department?: string;
  achievement?: number;
  periodStart: Date;
  periodEnd: Date;
  owner?: { id: string; firstName: string; lastName: string; corporateEmail: string };
  okr?: { id: string; title: string };
  keyResult?: { id: string; title: string };
  createdAt: Date;
  updatedAt: Date;

  static fromEntity(kpi: KPI): KPIResponseDto {
    const dto = new KPIResponseDto();
    dto.id = kpi.id;
    dto.title = kpi.title;
    dto.description = kpi.description;
    dto.type = kpi.type;
    dto.unit = kpi.unit;
    dto.targetValue = Number(kpi.targetValue);
    dto.actualValue = kpi.actualValue !== undefined ? Number(kpi.actualValue) : undefined;
    dto.baselineValue = kpi.baselineValue !== undefined ? Number(kpi.baselineValue) : undefined;
    dto.weight = Number(kpi.weight);
    dto.department = kpi.department;
    dto.periodStart = kpi.periodStart;
    dto.periodEnd = kpi.periodEnd;
    dto.createdAt = kpi.createdAt;
    dto.updatedAt = kpi.updatedAt;

    if (kpi.actualValue !== undefined && kpi.targetValue) {
      dto.achievement = Math.min(
        parseFloat(((Number(kpi.actualValue) / Number(kpi.targetValue)) * 100).toFixed(2)),
        100,
      );
    }

    if (kpi.owner) {
      dto.owner = {
        id: kpi.owner.id,
        firstName: kpi.owner.firstName,
        lastName: kpi.owner.lastName,
        corporateEmail: kpi.owner.corporateEmail,
      };
    }

    if (kpi.okr) {
      dto.okr = { id: kpi.okr.id, title: kpi.okr.title };
    }

    if (kpi.keyResult) {
      dto.keyResult = { id: kpi.keyResult.id, title: kpi.keyResult.title };
    }

    return dto;
  }
}

